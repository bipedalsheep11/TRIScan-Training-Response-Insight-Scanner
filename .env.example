# Copy this file to .env and fill in your API keys.
# At least one of the following is required.

# Primary: Anthropic Claude (recommended)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Fallback 1: Groq (fast cloud inference, free tier available)
# Get a key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Fallback 2: Ollama (local — no key needed, but requires Ollama running)
# Install: https://ollama.ai  |  Run: ollama pull qwen3:8b && ollama serve
